[Unit]
Description=Local Obsidian Knowledge Base API
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/kb-api/env
WorkingDirectory=/home/you/kbkb
ExecStart=/home/you/.local/bin/kb-api serve --config /home/you/kb-api/config.yaml
Restart=on-failure

[Install]
WantedBy=multi-user.target
